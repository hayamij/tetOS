    18 00000011 BE[C900]                    mov si, MSG_LOADING
    19 00000014 E85800                      call print_string
    20                                  
    21                                      ; Debug: print boot drive number
    22 00000017 A0[ED00]                    mov al, [BOOT_DRIVE]
    23 0000001A E85E00                      call print_hex_byte
    24                                  
    25                                      ; Load kernel from disk
    26 0000001D BB0010                      mov bx, KERNEL_OFFSET
    27 00000020 B606                        mov dh, KERNEL_SECTORS
    28 00000022 8A16[ED00]                  mov dl, [BOOT_DRIVE]
    29 00000026 E80B00                      call disk_load
    30                                  
    31 00000029 BE[DC00]                    mov si, MSG_LOADED
    32 0000002C E84000                      call print_string
    33                                  
    34 0000002F E8DA00                      call switch_to_pm
    35                                  
    36 00000032 EBFE                        jmp $
    37                                  
    38                                  ; Disk load routine
    39                                  ; Input: ES:BX = destination buffer, DH = sectors to read, DL = drive number
    40                                  disk_load:
    41 00000034 53                          push bx             ; Save buffer address
    42 00000035 51                          push cx             ; Save CX
    43 00000036 52                          push dx             ; Save drive and sector count
    44                                      
    45                                      ; Reset disk
    46 00000037 B400                        mov ah, 0x00
    47                                      ; DL still has drive number
    48 00000039 CD13                        int 0x13
    49 0000003B 7218                        jc .error
    50                                      
    51                                      ; Restore parameters
    52 0000003D 5A                          pop dx              ; DL = drive, DH = sector count
    53 0000003E 59                          pop cx              ; Restore CX
    54 0000003F 5B                          pop bx              ; Restore buffer
    55                                      
    56                                      ; Now save them again properly
    57 00000040 53                          push bx
    58 00000041 51                          push cx
    59 00000042 52                          push dx
    60                                      
    61                                      ; Setup read parameters
    62 00000043 B402                        mov ah, 0x02        ; Read function
    63 00000045 88F0                        mov al, dh          ; AL = number of sectors (from DH)
    64 00000047 B500                        mov ch, 0           ; Cylinder 0
    65 00000049 B102                        mov cl, 2           ; Sector 2 (1-indexed)
    66 0000004B B600                        mov dh, 0           ; Head 0
    67                                      ; DL = drive (already set)
    68                                      ; ES:BX = buffer (already set)
    69                                      
    70 0000004D CD13                        int 0x13
    71 0000004F 7204                        jc .error
    72                                      
    73                                      ; Success - clean stack
    74 00000051 5A                          pop dx
    75 00000052 59                          pop cx
    76 00000053 5B                          pop bx
    77 00000054 C3                          ret
    78                                  
    79                                  .error:
    80                                      ; Save error code to DI before cleaning stack  
    81 00000055 89C7                        mov di, ax          ; Save full AX to DI
    82                                      
    83                                      ; Clean stack
    84 00000057 5A                          pop dx
    85 00000058 59                          pop cx  
    86 00000059 5B                          pop bx
    87                                      
    88 0000005A BE[AA00]                    mov si, DISK_ERROR_MSG
    89 0000005D E80F00                      call print_string
    90                                      
    91                                      ; Print error code (in DI high byte)
    92 00000060 BE[BB00]                    mov si, MSG_ERROR_CODE
    93 00000063 E80900                      call print_string
    94 00000066 89F8                        mov ax, di          ; Restore AX
    95 00000068 88E0                        mov al, ah          ; Move error code to AL for printing
    96 0000006A E80E00                      call print_hex_byte
    97                                      
    98 0000006D EBFE                        jmp $
    99                                  
