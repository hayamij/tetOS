   101 0000006F B40E                        mov ah, 0x0e
   102                                  .loop:
   103 00000071 AC                          lodsb
   104 00000072 84C0                        test al, al
   105 00000074 7404                        jz .done
   106 00000076 CD10                        int 0x10
   107 00000078 EBF7                        jmp .loop
   108                                  .done:
   109 0000007A C3                          ret
   110                                  
   111                                  ; Print byte in AL as hex
   112                                  print_hex_byte:
   113 0000007B 50                          push ax
   114 0000007C B40E                        mov ah, 0x0e
   115 0000007E B030                        mov al, '0'
   116 00000080 CD10                        int 0x10
   117 00000082 B078                        mov al, 'x'
   118 00000084 CD10                        int 0x10
   119 00000086 58                          pop ax
   120                                      
   121 00000087 50                          push ax
   122 00000088 C0E804                      shr al, 4
   123 0000008B E80D00                      call .print_nibble
   124 0000008E 58                          pop ax
   125 0000008F 240F                        and al, 0x0F
   126 00000091 E80700                      call .print_nibble
   127                                      
   128 00000094 B020                        mov al, ' '
   129 00000096 B40E                        mov ah, 0x0e
   130 00000098 CD10                        int 0x10
   131 0000009A C3                          ret
   132                                  
   133                                  .print_nibble:
   134 0000009B 3C0A                        cmp al, 10
   135 0000009D 7C04                        jl .digit
   136 0000009F 0437                        add al, 'A' - 10
   137 000000A1 EB02                        jmp .print
   138                                  .digit:
   139 000000A3 0430                        add al, '0'
   140                                  .print:
